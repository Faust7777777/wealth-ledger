# Copy to /etc/finwealth/server.env and chmod 600.
# Do not commit real values.

FINWEALTH_REQUIRE_AUTH=true
FINWEALTH_AUTH_USERNAME=change-me
FINWEALTH_AUTH_PASSWORD_HASH=change-me

# Keep the Rust server loopback-only. Put Caddy/Nginx on 80/443 if exposing it.
FINWEALTH_RS_ADDR=127.0.0.1:8790

# Use "none" to disable outbound quote calls on a private VPS.
FINWEALTH_QUOTE_PROVIDER=yahoo
